PLAY_NEXA_VERSION=current
NAV_TABS=Home,GameHub,YTMusic,Movies,Me
REMOVED=Shorts,Library,YouTubeAPIv3,Trending
OFFLINE_FEATURES=MusicLibrary,VideoPlayer
ONLINE_FEATURES=MovieHub,YTMusic,GameHub
ADMIN_PATH=/admin
ENV_KEYS=SUPABASE_URL,SUPABASE_ANON,SERVICE_ROLE,GEMINI_API,APP_URL
NEVER_MODIFY=.env,useMusicPlayer.ts,useMediaLibrary.ts,MiniPlayer.tsx,NowPlaying.tsx,VinylDisc.tsx,EqualizerBars.tsx
DESIGN_BG=#0D0D0D
DESIGN_SURFACE=#1A1A2E
DESIGN_ACCENT=#7C3AED
DESIGN_CYAN=#06B6D4
DESIGN_BORDER=#2D2D44
NO_BACKDROP_BLUR=true
NO_STYLED_JSX=true
MAX_TRANSITION_MS=200
MIN_TOUCH_PX=44
ROUTES=/->Home,/music->MusicLibrary(offline),/video->VideoPlayer(offline),/movies->MovieHub(Supabase),/games->GameHub,/ytmusic->YTMusic(Supabase),/profile->Profile,/admin->AdminPanel
DEAD_ROUTES=/shorts->redirect(/),/library->redirect(/)
